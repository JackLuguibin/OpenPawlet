VITE_API_PORT=8000
# Use 127.0.0.1 for Vite -> FastAPI proxy (avoids Windows localhost/IPv6 vs IPv4 mismatch).
VITE_API_HOST=127.0.0.1
# Optional override for `/ws/state`. Wrong path breaks the handshake (use `/ws/state`, not `/ws`).
# Same-origin default is `ws(s)://<dev-host>/ws/state` via the `/ws` proxy to FastAPI on VITE_API_* .
# VITE_CONSOLE_WS_URL=ws://127.0.0.1:8000/ws/state
# 可选：覆盖默认的 /openpawlet-ws（代理到 OpenPawlet 内置 websocket）；设为空可禁用控制台经 WS 发消息
# VITE_OPENPAWLET_WS_BASE=/openpawlet-ws
# 可选：握手时附加 ?token=（与 OpenPawlet `channels.websocket` 的 token / issued token 配置一致）
# VITE_OPENPAWLET_WS_TOKEN=
